generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "classic"
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  company   String?
  createdAt DateTime @default(now())
}
